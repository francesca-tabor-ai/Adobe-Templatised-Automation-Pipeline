{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Variant",
  "description": "Single variant record for templatized creative automation",
  "type": "object",
  "required": ["variant_id", "market", "language", "channel"],
  "properties": {
    "variant_id": { "type": "string", "description": "Unique identifier for this variant" },
    "campaign_id": { "type": "string", "description": "Campaign identifier (optional; CIF feature store)" },
    "market": { "type": "string", "description": "Market code e.g. US, DE, FR" },
    "language": { "type": "string", "description": "Language code e.g. en, de, fr" },
    "channel": { "type": "string", "description": "Delivery channel e.g. print_a4, social_1_1" },
    "size": { "type": "string", "description": "Output size label" },
    "aspect_ratio": { "type": "string", "description": "e.g. 16:9, 1:1, 9:16" },
    "headline": { "type": "string" },
    "subheadline": { "type": "string" },
    "cta": { "type": "string" },
    "legal_disclaimer_id": { "type": "string" },
    "product_image_id": { "type": "string" },
    "background_image_id": { "type": "string" },
    "compliance_version": { "type": "string" },
    "approved": { "type": "boolean", "default": false },
    "start_date": { "type": "string", "format": "date" },
    "end_date": { "type": "string", "format": "date" },
    "hypothesis_id": { "type": "string" },
    "variable_changed": { "type": "string" },
    "ai_generated": { "type": "boolean", "default": false, "description": "Whether this variant was AI-generated" },
    "ai_translated": { "type": "boolean", "default": false, "description": "Whether text fields were AI-translated" },
    "parent_variant_id": { "type": "string", "description": "Source variant this was generated/translated from" },
    "ai_model": { "type": "string", "description": "AI model used for generation/translation" },
    "ai_provider": { "type": "string", "description": "AI provider (google_gemini, anthropic_claude, openai)" },
    "ai_score": { "type": "number", "description": "AI-assigned quality/relevance score (0.0-1.0)" },
    "ai_ranking": { "type": "integer", "description": "Rank among generated variations" },
    "source_language": { "type": "string", "description": "Original language before translation" },
    "background_prompt": { "type": "string", "description": "Prompt used for AI background generation" },
    "ai_generation_run_id": { "type": "string", "description": "Run ID of the AI generation pass" },
    "ai_cost_usd": { "type": "number", "description": "Cost of AI API call for this variant" },
    "video_prompt": { "type": "string", "description": "Enhanced cinematic video prompt from multimodal optimization" },
    "video_camera_movement": { "type": "string", "description": "Primary camera technique for video" },
    "video_lighting": { "type": "string", "description": "Lighting setup description for video" },
    "video_color_grade": { "type": "string", "description": "Color grading notes for video" },
    "video_duration_seconds": { "type": "number", "description": "Recommended clip duration in seconds" },
    "video_style_reference": { "type": "string", "description": "Film/director style reference" },
    "prompt_optimized": { "type": "boolean", "default": false, "description": "Whether prompt was enhanced via multimodal optimization" }
  }
}
