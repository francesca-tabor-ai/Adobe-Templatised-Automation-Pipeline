{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ConceptualVariantLog",
  "type": "object",
  "required": ["entries"],
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["conceptName", "formatIds"],
        "properties": {
          "conceptName": { "type": "string" },
          "formatIds": { "type": "array", "items": { "type": "string" } },
          "differences": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
