{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AmbiguityLog",
  "type": "object",
  "required": ["entries"],
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["elementId", "description", "requiresManualReview"],
        "properties": {
          "elementId": { "type": "string" },
          "description": { "type": "string" },
          "suggestedClassification": { "type": ["string", "null"], "enum": ["sacred", "flexible", "sku", null] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "requiresManualReview": { "type": "boolean" }
        }
      }
    }
  }
}
